# Terraform local state (even when using remote backend)
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfplan

prod/

# Terraform lock file (KEEP this tracked)
# DO NOT ignore .terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config
.terraformrc
terraform.rc

# Sensitive variable files
*.tfvars
*.tfvars.json

# Local environment files
.env
.env.*

# OS / editor noise
.DS_Store
.vscode/
.idea/

# Optional: local plan outputs
plan.out
